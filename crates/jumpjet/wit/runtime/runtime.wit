package jumpjet:runtime;

/// How Jumpjet interfaces with your game :)
///
/// A singleplayer game implements just `client`. A multiplayer game implements
/// `client` (which renders) in one component and `server` (the headless simulation) in another.
interface client {
  /// Jumpjet runs this when your game starts up. Return an error to abort startup.
  init: func() -> result<_, string>;
  /// Jumpjet runs this update loop at a fixed frequency per second. Use this for game logic.
  update: func(time: f64, delta-time: f64);
  /// Jumpjet runs this render loop at a variable frequency depending on various performance constraints. Use this for render logic.
  render: func(time: f64, alpha: f64);
}

/// The server side of a multiplayer game: it has no render loop, it runs headless.
interface server {
  /// Jumpjet runs this when your server starts up. Return an error to abort startup.
  init: func() -> result<_, string>;
  /// Jumpjet runs this update loop at a fixed frequency per second. Use this for game logic.
  update: func(time: f64, delta-time: f64);
}

/// The full client/singleplayer runtime
world client-runtime {
  import debug;
  import audio;
  import input;
  import gpu;
  import tasks;
  import image;
  import model;
  import compression;
  // import network;
  import storage;
  import window;

  export client;
}

/// The headless server runtime
world server-runtime {
  import debug;
  import tasks;
  import storage;
  // import network;
  // import compression;  // if loading packed data
  // import model;        // if mesh physics

  export server;
}
