package jumpjet:runtime;

/// (De)compression over byte streams. Bytes flow as host-backed streams, so they
/// never cross the wasm boundary.
interface compression {
  use tasks.{buffer};

  /// Supported compression formats.
  enum compression-format {
    /// gzip container (RFC 1952).
    gzip,
    /// Raw DEFLATE stream (RFC 1951).
    deflate,
    /// Brotli (RFC 7932).
    brotli
  }

  variant compression-error {
    /// The data couldn't be processed (corrupt input).
    invalid-data(string)
  }

  /// Compress a `buffer` with `format`, returning a new `buffer`. Synchronous.
  compress: func(data: borrow<buffer>, format: compression-format) -> result<buffer, compression-error>;
  /// Decompress a `buffer` with `format`, returning a new `buffer`. Synchronous.
  decompress: func(data: borrow<buffer>, format: compression-format) -> result<buffer, compression-error>;
}
